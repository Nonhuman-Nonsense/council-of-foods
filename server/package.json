{
  "name": "council-of-foods-server",
  "author": "Nonhuman Nonsense",
  "license": "CC BY-NC 4.0",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server/server.js",
    "build": "tsc && tsc-alias",
    "e2e-server": "cross-env NODE_ENV=test tsx server.ts",
    "dev": "cross-env NODE_ENV=development USE_TEST_OPTIONS=true nodemon --exec \"tsc --noEmit && tsx server.ts\"",
    "proto": "cross-env NODE_ENV=prototype node dist/server/server.js",
    "protodev": "cross-env NODE_ENV=prototype nodemon --exec \"tsc --noEmit && tsx server.ts\"",
    "type-check": "tsc --noEmit",
    "test": "npm run type-check && vitest run",
    "test:watch": "npm run type-check && vitest",
    "test:unit": "npm run type-check && vitest run --config vitest.unit.config.ts",
    "test:integration": "npm run type-check && vitest run --config vitest.integration.config.ts",
    "test:fast": "cross-env TEST_MODE=fast npm run test",
    "test:full": "cross-env TEST_MODE=full npm run test",
    "test:coverage": "npm run test -- --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "docker": "node scripts/docker.mjs",
    "push": "node scripts/push.mjs"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "mongodb": "^7.5.0",
    "music-metadata": "^11.14.0",
    "openai": "^6.48.0",
    "remove-markdown": "^0.6.4",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/remove-markdown": "^0.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.8"
  },
  "nodemonConfig": {
    "watch": [
      "server.ts",
      "src",
      "global-options.json",
      "test-options.json",
      "../shared",
      ".env"
    ],
    "ext": "ts,js,json"
  }
}
