{
  "name": "council-of-forest-server",
  "author": "Nonhuman Nonsense",
  "license": "CC BY-NC 4.0",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server/server.js",
    "build": "tsc && tsc-alias",
    "e2e-server": "cross-env NODE_ENV=test tsx server.ts",
    "dev": "npm run type-check && cross-env NODE_ENV=development USE_TEST_OPTIONS=true concurrently -n types,server -c yellow,cyan \"tsc --noEmit --watch --preserveWatchOutput\" \"nodemon --exec tsx server.ts\"",
    "proto": "cross-env NODE_ENV=prototype node dist/server/server.js",
    "protodev": "npm run type-check && cross-env NODE_ENV=prototype nodemon --exec tsx server.ts",
    "type-check": "tsc --noEmit",
    "test": "npm run type-check && vitest run",
    "test:watch": "npm run type-check && vitest",
    "test:unit": "npm run type-check && vitest run --config vitest.unit.config.ts",
    "test:integration": "npm run type-check && vitest run --config vitest.integration.config.ts",
    "test:fast": "cross-env TEST_MODE=fast npm run test",
    "test:full": "cross-env TEST_MODE=full npm run test",
    "test:coverage": "npm run test -- --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docker": "docker build ../. -t nonhumannonsense/council-of-forest:latest --platform linux/amd64",
    "docker:test": "docker build ../. -t nonhumannonsense/council-of-forest:test --platform linux/amd64",
    "docker:proto": "docker build ../. -t nonhumannonsense/council-of-forest:proto -f ../prototype/Dockerfile --platform linux/amd64",
    "push": "docker push nonhumannonsense/council-of-forest:latest",
    "push:test": "docker push nonhumannonsense/council-of-forest:test",
    "push:proto": "docker push nonhumannonsense/council-of-forest:proto"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "google-auth-library": "^10.7.0",
    "mongodb": "^7.3.0",
    "music-metadata": "^11.13.0",
    "openai": "^6.43.0",
    "remove-markdown": "^0.6.4",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/remove-markdown": "^0.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "nodemonConfig": {
    "watch": [
      "server.ts",
      "src",
      "global-options.json",
      "test-options.json",
      "../shared",
      ".env"
    ],
    "ext": "ts,js,json"
  }
}
