{
  "name": "concil-of-foods-server",
  "author": "Nonhuman Nonsense",
  "license": "CC BY-NC 4.0",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server/server.js",
    "build": "tsc && tsc-alias",
    "e2e-server": "cross-env NODE_ENV=test tsx server.ts",
    "dev": "npm run type-check && cross-env NODE_ENV=development USE_TEST_OPTIONS=true concurrently -n types,server -c yellow,cyan \"tsc --noEmit --watch --preserveWatchOutput\" \"nodemon --exec tsx server.ts\"",
    "proto": "cross-env NODE_ENV=prototype node dist/server/server.js",
    "protodev": "npm run type-check && cross-env NODE_ENV=prototype nodemon --exec tsx server.ts",
    "type-check": "tsc --noEmit",
    "test": "npm run type-check && vitest run",
    "test:watch": "vitest",
    "test:fast": "cross-env TEST_MODE=fast vitest run",
    "test:full": "cross-env TEST_MODE=full vitest run",
    "test:coverage": "vitest run --coverage",
    "docker": "docker build ../. -t nonhumannonsense/council-of-forest:latest --platform linux/amd64",
    "push": "docker push nonhumannonsense/council-of-forest:latest"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "google-auth-library": "^10.6.2",
    "mongodb": "^7.1.1",
    "music-metadata": "^11.12.3",
    "openai": "^6.33.0",
    "remove-markdown": "^0.6.3",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/remove-markdown": "^0.3.4",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.15"
  },
  "nodemonConfig": {
    "watch": [
      "server.ts",
      "src",
      "global-options.json",
      "test-options.json",
      ".env"
    ],
    "ext": "ts,js,json"
  }
}
